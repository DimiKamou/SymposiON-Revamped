# Cloud Functions environment variables (firebase-functions v7).
# Copy this file to `.env` (which is gitignored) and fill in real values,
# then deploy: `firebase deploy --only functions:gradeAnswer`.
#
# The key is read server-side only — it is never sent to the browser.

# Required for live AI grading (Ανάπτυξη / Ορισμοί / Πηγή / Σ-Λ / Σύγκριση / Τεστ).
# Without it, the grader returns 503 and the panel uses its offline fallback.
ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6
